{
  "openapi": "3.1.0",
  "info": {
    "title": "Social Network API",
    "description": "HTTP contract for the Go backend and React JavaScript frontend. Posting supports privacy, nested comments, JPEG/PNG/GIF media, mutually exclusive like/dislike votes, author edits, and soft-deletion tombstones.",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Session authentication"
    },
    {
      "name": "Users",
      "description": "Current user and profile activity"
    },
    {
      "name": "Posts",
      "description": "Timeline, profile, and group posts"
    },
    {
      "name": "Comments",
      "description": "Nested post discussions"
    },
    {
      "name": "Votes",
      "description": "Mutually exclusive like/dislike state"
    },
    {
      "name": "Chats",
      "description": "Direct messages and group chat rooms"
    },
    {
      "name": "Groups",
      "description": "Group and event invitations"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_token"
      }
    },
    "schemas": {
      "Response": {
        "type": "object",
        "required": ["status", "message"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "message": {
            "type": "string"
          },
          "data": {
            "description": "The response payload."
          }
        }
      },
      "PrivateUser": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicUser"
          },
          {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "format": "email"
              },
              "dob": {
                "type": "string",
                "format": "date"
              }
            }
          }
        ]
      },
      "ChatRoom": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Group ID or a generated DM Thread ID"
          },
          "type": {
            "type": "string",
            "enum": ["dm", "group"]
          },
          "name": {
            "type": "string",
            "description": "Group title or the other user's name"
          },
          "last_message": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "VoteRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["vote"],
        "properties": {
          "vote": {
            "type": "string",
            "enum": ["like", "dislike"]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "message"],
        "properties": {
          "status": {
            "type": "string",
            "const": "error"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "PublicUser": {
        "type": "object",
        "required": ["id", "first_name", "last_name", "nickname", "avatar"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "nickname": {
            "type": ["string", "null"]
          },
          "avatar": {
            "type": ["string", "null"]
          }
        }
      },
      "CurrentUser": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicUser"
          },
          {
            "type": "object",
            "required": ["email", "date_of_birth", "about_me", "is_public"],
            "properties": {
              "email": {
                "type": "string",
                "format": "email"
              },
              "date_of_birth": {
                "type": "string",
                "format": "date"
              },
              "about_me": {
                "type": ["string", "null"]
              },
              "is_public": {
                "type": "boolean"
              }
            }
          }
        ]
      },
      "ViewerVote": {
        "type": "string",
        "enum": ["like", "dislike", "none"]
      },
      "Post": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "deleted",
          "author",
          "group_id",
          "content",
          "image_url",
          "privacy",
          "comment_count",
          "like_count",
          "dislike_count",
          "viewer_vote",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "deleted": {
            "type": "boolean",
            "const": false
          },
          "author": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "group_id": {
            "type": ["string", "null"],
            "format": "uuid"
          },
          "content": {
            "type": "string"
          },
          "image_url": {
            "type": ["string", "null"]
          },
          "privacy": {
            "type": "string",
            "enum": ["public", "almost_private", "private"],
            "description": "Ignored for authorization when group_id is present; accepted group membership is then required."
          },
          "comment_count": {
            "type": "integer",
            "minimum": 0
          },
          "like_count": {
            "type": "integer",
            "minimum": 0
          },
          "dislike_count": {
            "type": "integer",
            "minimum": 0
          },
          "viewer_vote": {
            "$ref": "#/components/schemas/ViewerVote"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        }
      },
      "DeletedPost": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "deleted"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "deleted": {
            "type": "boolean",
            "const": true
          }
        }
      },
      "PostDTO": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Post"
          },
          {
            "$ref": "#/components/schemas/DeletedPost"
          }
        ]
      },
      "Comment": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "deleted",
          "post_id",
          "parent_comment_id",
          "author",
          "content",
          "image_url",
          "like_count",
          "dislike_count",
          "viewer_vote",
          "created_at",
          "updated_at",
          "replies"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "deleted": {
            "type": "boolean",
            "const": false
          },
          "post_id": {
            "type": "string",
            "format": "uuid"
          },
          "parent_comment_id": {
            "type": ["string", "null"],
            "format": "uuid"
          },
          "author": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "content": {
            "type": "string"
          },
          "image_url": {
            "type": ["string", "null"]
          },
          "like_count": {
            "type": "integer",
            "minimum": 0
          },
          "dislike_count": {
            "type": "integer",
            "minimum": 0
          },
          "viewer_vote": {
            "$ref": "#/components/schemas/ViewerVote"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "replies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommentDTO"
            }
          }
        }
      },
      "DeletedComment": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "deleted", "replies"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "deleted": {
            "type": "boolean",
            "const": true
          },
          "replies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommentDTO"
            }
          }
        }
      },
      "CommentDTO": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Comment"
          },
          {
            "$ref": "#/components/schemas/DeletedComment"
          }
        ]
      },
      "VoteResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["like_count", "dislike_count", "viewer_vote"],
        "properties": {
          "like_count": {
            "type": "integer",
            "minimum": 0
          },
          "dislike_count": {
            "type": "integer",
            "minimum": 0
          },
          "viewer_vote": {
            "$ref": "#/components/schemas/ViewerVote"
          }
        }
      },
      "PostResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "data"],
        "properties": {
          "status": {
            "type": "string",
            "const": "success"
          },
          "data": {
            "$ref": "#/components/schemas/PostDTO"
          }
        }
      },
      "CommentResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "data"],
        "properties": {
          "status": {
            "type": "string",
            "const": "success"
          },
          "data": {
            "$ref": "#/components/schemas/CommentDTO"
          }
        }
      },
      "PostListResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "data", "pagination"],
        "properties": {
          "status": {
            "type": "string",
            "const": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PostDTO"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "CommentListResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "data", "pagination"],
        "properties": {
          "status": {
            "type": "string",
            "const": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommentDTO"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "additionalProperties": false,
        "required": ["limit", "offset", "has_more"],
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1
          },
          "offset": {
            "type": "integer",
            "minimum": 0
          },
          "has_more": {
            "type": "boolean"
          }
        }
      }
    },
    "parameters": {
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Malformed request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing, invalid, or expired session",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "The resource exists but the current user may not access it",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "The requested operation conflicts with current resource state",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request fields failed validation",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users / Search users",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search by name, nickname, or email",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PublicUser"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/me/comments": {
      "get": {
        "tags": ["Users", "Comments"],
        "summary": "Get all comments made by the authenticated user",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of the user's comments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CommentDTO"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}/followers": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["Users"],
        "summary": "Get a user's followers",
        "responses": {
          "200": {
            "description": "Array of PublicUsers"
          }
        }
      }
    },
    "/users/{id}/following": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["Users"],
        "summary": "Get users followed by this user",
        "responses": {
          "200": {
            "description": "Array of PublicUsers"
          }
        }
      }
    },
    "/users/{id}/follow": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["Users"],
        "summary": "Follow a user",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Followed or request pending"
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Unfollow a user or cancel follow request",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully unfollowed"
          }
        }
      }
    },
    "/chats": {
      "get": {
        "tags": ["Chats"],
        "summary": "Get all active chat rooms",
        "description": "Returns a list of all DMs and Group chats the user is part of, sorted by recent activity.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ChatRoom"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/chats/dm": {
      "post": {
        "tags": ["Chats"],
        "summary": "Open a direct message with a user",
        "description": "Creates or retrieves an existing DM thread with the target user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["target_user_id"],
                "properties": {
                  "target_user_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "DM room opened"
          }
        }
      }
    },
    "/groups/{id}/invite": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["Groups"],
        "summary": "Invite a user to a group",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invitation sent"
          }
        }
      }
    },
    "/events/{id}/invite": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["Groups"],
        "summary": "Invite a user to an event",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Invitation sent"
          }
        }
      }
    },
    "/users/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "first_name",
                  "last_name",
                  "date_of_birth"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "date_of_birth": {
                    "type": "string",
                    "format": "date"
                  },
                  "avatar": {
                    "type": ["string", "null"]
                  },
                  "nickname": {
                    "type": ["string", "null"]
                  },
                  "about_me": {
                    "type": ["string", "null"]
                  },
                  "is_public": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/users/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create a session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session cookie set"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Delete the current session",
        "responses": {
          "200": {
            "description": "Session removed"
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["Users"],
        "summary": "Get the current user",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUser"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/{id}/posts": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ResourceId"
        },
        {
          "$ref": "#/components/parameters/Limit"
        },
        {
          "$ref": "#/components/parameters/Offset"
        }
      ],
      "get": {
        "tags": ["Users", "Posts"],
        "summary": "Get posts visible on a user's profile",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Visible profile posts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/posts": {
      "get": {
        "tags": ["Posts"],
        "summary": "Get the home feed or a group feed",
        "description": "Without group_id, excludes group posts and applies ordinary privacy. With group_id, requires accepted membership and returns only that group's posts.",
        "security": [
          {
