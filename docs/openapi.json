          }
        },
        "responses": {
          "200": {
            "description": "Vote set or changed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoteResponse"
                }
              }
            }
          },
          "404": {
            "description": "Post not found"
          },
          "409": {
            "description": "Deleted posts cannot be voted on"
          }
        }
      },
      "delete": {
        "tags": ["Posts"],
        "summary": "Remove the current user's vote from a post",
