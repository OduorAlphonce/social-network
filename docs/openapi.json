    "/posts/{id}/vote": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "put": {
        "tags": ["Posts"],
        "summary": "Set or change the current user's vote on a post",
        "description": "Creates or replaces the authenticated user's single vote. Setting the existing value is idempotent; changing from like to dislike or vice versa updates both counters atomically. Deleted posts cannot be voted on.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
